#!/bin/bash
# zebrahttp — CUPS backend that forwards print jobs to the Zebra Label Parser API.
#
# Install to: /usr/lib/cups/backend/zebrahttp (or /usr/libexec/cups/backend/)
# Permissions: root:root 0755
#
# Device URI format:
#   zebrahttp://HOST:PORT/api/labels/print?printer=PRINTER_NAME&token=HA_TOKEN
#
# Examples:
#   # Local server (no auth):
#   lpadmin -p ZebraLabel -E \
#     -v "zebrahttp://localhost:8099/api/labels/print?printer=Zebra_LP2844" \
#     -m raw -D "Zebra Shipping Label Printer" -L "Network"
#
#   # Remote Home Assistant (with auth token):
#   lpadmin -p ZebraLabel -E \
#     -v "zebrahttp://homeassistant.local:8099/api/labels/print?printer=Zebra_LP2844&token=eyJ..." \
#     -m raw -D "Zebra Shipping Label Printer" -L "Network"
#
# CUPS backend protocol:
#   $0                         → device discovery (list available devices)
#   $0 JOB USER TITLE COPIES OPTIONS [FILE]
#                              → print a job (FILE or stdin)

# --- Device discovery mode (no arguments) ---
if [ "$#" -eq 0 ]; then
    echo 'network zebrahttp "Unknown" "Zebra HTTP Label Printer" ""'
    exit 0
fi

# --- Print mode ---
JOB_ID="$1"
USER="$2"
TITLE="$3"
COPIES="$4"
OPTIONS="$5"
FILE="$6"

# Parse DEVICE_URI set by CUPS: zebrahttp://host:port/path?printer=NAME
URI_BODY="${DEVICE_URI#zebrahttp://}"
URL_PATH="http://${URI_BODY%%\?*}"

# Extract query parameters from device URI
QUERY=""
[[ "$DEVICE_URI" == *"?"* ]] && QUERY="${DEVICE_URI#*\?}"

PRINTER=""
if [[ "$QUERY" == *"printer="* ]]; then
    PRINTER="${QUERY#*printer=}"
    PRINTER="${PRINTER%%&*}"
fi

TOKEN=""
if [[ "$QUERY" == *"token="* ]]; then
    TOKEN="${QUERY#*token=}"
    TOKEN="${TOKEN%%&*}"
fi

# Read from file argument or stdin
TMPFILE=""
if [ -n "$FILE" ]; then
    INPUT="$FILE"
else
    TMPFILE=$(mktemp /tmp/cups-zebrahttp-XXXXXX)
    cat > "$TMPFILE"
    INPUT="$TMPFILE"
fi

# Derive a filename from the job title
FILENAME="${TITLE:-label}.pdf"

echo "INFO: zebrahttp: Sending job $JOB_ID \"$TITLE\" to $URL_PATH (printer=$PRINTER${TOKEN:+, auth=yes})" >&2

# Build curl args (-sS: silent but show errors)
CURL_ARGS=(-sS -w "%{http_code}" --connect-timeout 10 --max-time 60)
CURL_ARGS+=(-X POST)
CURL_ARGS+=(-F "file=@${INPUT};filename=${FILENAME}")
if [ -n "$PRINTER" ]; then
    CURL_ARGS+=(-F "printer=${PRINTER}")
fi
if [ -n "$TOKEN" ]; then
    CURL_ARGS+=(-H "Authorization: Bearer ${TOKEN}")
fi

# Capture HTTP status code on stdout (-w); curl errors (-S) go to CURL_LOG via stderr redirect;
# response body is discarded (we only need the status code for success/failure).
CURL_LOG=$(mktemp /tmp/cups-zebrahttp-log-XXXXXX)
HTTP_CODE=$(curl "${CURL_ARGS[@]}" -o /dev/null "$URL_PATH" 2>"$CURL_LOG")
CURL_EXIT=$?

# Clean up temp file
[ -n "$TMPFILE" ] && rm -f "$TMPFILE"

if [ "$CURL_EXIT" -ne 0 ]; then
    # curl itself failed (connection refused, DNS error, timeout, etc.)
    echo "ERROR: zebrahttp: Job $JOB_ID — curl exit $CURL_EXIT connecting to $URL_PATH" >&2
    # Show curl's error output in CUPS log for diagnosis
    [ -s "$CURL_LOG" ] && sed 's/^/ERROR: zebrahttp:   /' "$CURL_LOG" >&2
    rm -f "$CURL_LOG"
    # Exit 6 = CUPS_BACKEND_RETRY — tells CUPS to retry later instead of stopping the queue
    exit 6
elif [ "$HTTP_CODE" -ge 200 ] 2>/dev/null && [ "$HTTP_CODE" -lt 300 ] 2>/dev/null; then
    echo "INFO: zebrahttp: Job $JOB_ID completed (HTTP $HTTP_CODE)" >&2
    rm -f "$CURL_LOG"
    exit 0
else
    echo "ERROR: zebrahttp: Job $JOB_ID failed (HTTP ${HTTP_CODE:-unknown})" >&2
    rm -f "$CURL_LOG"
    exit 1
fi
