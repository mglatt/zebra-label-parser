#!/bin/bash
# zebrahttp â€” CUPS backend that forwards print jobs to the Zebra Label Parser API.
#
# Install to: /usr/lib/cups/backend/zebrahttp (or /usr/libexec/cups/backend/)
# Permissions: root:root 0755
#
# Device URI format:
#   zebrahttp://HOST:PORT/api/labels/print?printer=PRINTER_NAME&api_key=KEY
#
# Examples:
#   # No auth:
#   lpadmin -p ZebraLabel -E \
#     -v "zebrahttp://localhost:8099/api/labels/print?printer=Zebra_LP2844" \
#     -m raw -D "Zebra Shipping Label Printer" -L "Network"
#
#   # With API key:
#   lpadmin -p ZebraLabel -E \
#     -v "zebrahttp://homeassistant.local:8099/api/labels/print?printer=Zebra_LP2844&api_key=mykey" \
#     -m raw -D "Zebra Shipping Label Printer" -L "Network"
#
# CUPS backend protocol:
#   $0                         â†’ device discovery (list available devices)
#   $0 JOB USER TITLE COPIES OPTIONS [FILE]
#                              â†’ print a job (FILE or stdin)

# --- Device discovery mode (no arguments) ---
if [ "$#" -eq 0 ]; then
    echo 'network zebrahttp "Unknown" "Zebra HTTP Label Printer" ""'
    exit 0
fi

# --- Print mode ---
JOB_ID="$1"
USER="$2"
TITLE="$3"
COPIES="$4"
OPTIONS="$5"
FILE="$6"

# Parse DEVICE_URI set by CUPS: zebrahttp://host:port/path?printer=NAME
URI_BODY="${DEVICE_URI#zebrahttp://}"
URL_PATH="http://${URI_BODY%%\?*}"

# Extract query parameters from device URI
QUERY=""
[[ "$DEVICE_URI" == *"?"* ]] && QUERY="${DEVICE_URI#*\?}"

PRINTER=""
if [[ "$QUERY" == *"printer="* ]]; then
    PRINTER="${QUERY#*printer=}"
    PRINTER="${PRINTER%%&*}"
fi

API_KEY=""
if [[ "$QUERY" == *"api_key="* ]]; then
    API_KEY="${QUERY#*api_key=}"
    API_KEY="${API_KEY%%&*}"
fi

# Read from file argument or stdin
TMPFILE=""
if [ -n "$FILE" ]; then
    INPUT="$FILE"
else
    TMPFILE=$(mktemp /tmp/cups-zebrahttp-XXXXXX)
    cat > "$TMPFILE"
    INPUT="$TMPFILE"
fi

# Derive a filename from the job title â€” preserve original extension if present,
# otherwise detect the format from magic bytes.  Correct extensions prevent the
# API from misdetecting the file type.
FILENAME="${TITLE:-label}"
case "$FILENAME" in
    *.*) ;; # already has extension
    *)
        # Peek at the first bytes of the input to detect format
        HEAD=$(head -c 32 "$INPUT" 2>/dev/null || true)
        if echo "$HEAD" | grep -qiE '^\^XA|^\^FO|^\^CT'; then
            FILENAME="${FILENAME}.zpl"
        elif echo "$HEAD" | grep -q '^%!PS'; then
            # PostScript â€” macOS CUPS may send PS instead of PDF
            FILENAME="${FILENAME}.ps"
        elif echo "$HEAD" | grep -q '^%PDF'; then
            FILENAME="${FILENAME}.pdf"
        elif printf '%s' "$HEAD" | od -A n -t x1 -N 8 2>/dev/null | grep -q '89 50 4e 47'; then
            FILENAME="${FILENAME}.png"
        elif printf '%s' "$HEAD" | od -A n -t x1 -N 2 2>/dev/null | grep -q 'ff d8'; then
            FILENAME="${FILENAME}.jpg"
        else
            # Default to PDF â€” the API will sniff magic bytes as a fallback
            FILENAME="${FILENAME}.pdf"
        fi
        ;;
esac

echo "INFO: zebrahttp: Sending job $JOB_ID \"$TITLE\" to $URL_PATH (printer=$PRINTER${API_KEY:+, auth=yes})" >&2

# Build curl args (-sS: silent but show errors)
CURL_ARGS=(-sS -w "%{http_code}" --connect-timeout 10 --max-time 60)
CURL_ARGS+=(-X POST)
CURL_ARGS+=(-F "file=@${INPUT};filename=${FILENAME}")
if [ -n "$PRINTER" ]; then
    CURL_ARGS+=(-F "printer=${PRINTER}")
fi
if [ -n "$API_KEY" ]; then
    CURL_ARGS+=(-H "X-API-Key: ${API_KEY}")
fi

# Capture HTTP status code on stdout (-w); curl errors go to CURL_LOG via stderr redirect;
# response body is captured for error diagnostics.
CURL_LOG=$(mktemp /tmp/cups-zebrahttp-log-XXXXXX)
RESP_BODY=$(mktemp /tmp/cups-zebrahttp-resp-XXXXXX)
HTTP_CODE=$(curl "${CURL_ARGS[@]}" -o "$RESP_BODY" "$URL_PATH" 2>"$CURL_LOG")
CURL_EXIT=$?

# Clean up temp file
[ -n "$TMPFILE" ] && rm -f "$TMPFILE"

# Helper: extract error detail from JSON response body (best-effort)
_extract_error() {
    # Try to pull "error" or "detail" field from JSON, fall back to first 500 chars
    if command -v python3 >/dev/null 2>&1; then
        python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('error') or d.get('detail') or d.get('print_result',{}).get('error') or json.dumps(d.get('stages',[])))
except: print(sys.stdin.read()[:500])
" < "$1" 2>/dev/null
    else
        head -c 500 "$1" 2>/dev/null
    fi
}

if [ "$CURL_EXIT" -ne 0 ]; then
    # curl itself failed (connection refused, DNS error, timeout, etc.)
    echo "ERROR: zebrahttp: Job $JOB_ID â€” curl exit $CURL_EXIT connecting to $URL_PATH" >&2
    # Show curl's error output in CUPS log for diagnosis
    [ -s "$CURL_LOG" ] && sed 's/^/ERROR: zebrahttp:   /' "$CURL_LOG" >&2
    rm -f "$CURL_LOG" "$RESP_BODY"
    # Exit 6 = CUPS_BACKEND_RETRY â€” tells CUPS to retry later instead of stopping the queue
    exit 6
elif [ "$HTTP_CODE" -ge 200 ] 2>/dev/null && [ "$HTTP_CODE" -lt 300 ] 2>/dev/null; then
    echo "INFO: zebrahttp: Job $JOB_ID completed (HTTP $HTTP_CODE)" >&2
    rm -f "$CURL_LOG" "$RESP_BODY"
    exit 0
elif [ "$HTTP_CODE" -ge 500 ] 2>/dev/null && [ "$HTTP_CODE" -lt 600 ] 2>/dev/null; then
    # Server-side failure â€” log the error detail and retry
    ERR_DETAIL=$(_extract_error "$RESP_BODY")
    echo "ERROR: zebrahttp: Job $JOB_ID â€” server error (HTTP $HTTP_CODE): $ERR_DETAIL" >&2
    rm -f "$CURL_LOG" "$RESP_BODY"
    # Exit 6 = CUPS_BACKEND_RETRY â€” server may recover
    exit 6
else
    # Client error (4xx) or other â€” permanent failure
    ERR_DETAIL=$(_extract_error "$RESP_BODY")
    echo "ERROR: zebrahttp: Job $JOB_ID failed (HTTP ${HTTP_CODE:-unknown}): $ERR_DETAIL" >&2
    rm -f "$CURL_LOG" "$RESP_BODY"
    exit 1
fi
