<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<!--
  Avahi service file for Bonjour/mDNS printer discovery.
  Install to: /etc/avahi/services/zebra-label-printer.service

  This advertises the CUPS-shared "ZebraLabel" queue so macOS
  computers on the network auto-discover it as a printer.
-->
<service-group>
  <name replace-wildcards="yes">Zebra Label Printer @ %h</name>
  <service>
    <type>_ipp._tcp</type>
    <subtype>_universal._sub._ipp._tcp</subtype>
    <port>631</port>
    <txt-record>txtvers=1</txt-record>
    <txt-record>qtotal=1</txt-record>
    <txt-record>Transparent=T</txt-record>
    <txt-record>URF=none</txt-record>
    <txt-record>rp=printers/ZebraLabel</txt-record>
    <txt-record>pdl=application/pdf,application/postscript,image/jpeg,image/png</txt-record>
    <txt-record>product=(Zebra Label Printer)</txt-record>
    <txt-record>printer-state=3</txt-record>
    <txt-record>media-ready=custom_4x6in_4x6in</txt-record>
    <txt-record>note=Zebra Thermal Shipping Labels (4x6)</txt-record>
  </service>
</service-group>
