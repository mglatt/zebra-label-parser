# Optional API key to protect direct access to port 8099.
# When set, requests must include X-API-Key header or ?api_key= query param.
# ZLP_API_KEY=

# Anthropic API key for Claude Vision label extraction (optional).
# Without this, a heuristic fallback crops the label region from
# letter-size pages. Add a key for accurate multi-page extraction.
ZLP_ANTHROPIC_API_KEY=

# Claude model for label extraction
# ZLP_CLAUDE_MODEL=claude-sonnet-4-20250514

# CUPS printer name (e.g., "Zebra_LP2844")
# Leave blank to select from the web UI each time
ZLP_PRINTER_NAME=

# Remote CUPS server (leave blank to use the local CUPS socket).
# Required when CUPS runs on a different machine than this container.
# ZLP_CUPS_SERVER=192.168.1.50:631

# Label dimensions (default: 4x6 inches at 203 DPI)
# ZLP_LABEL_WIDTH_INCHES=4.0
# ZLP_LABEL_HEIGHT_INCHES=6.0
# ZLP_LABEL_DPI=203

# Left offset in dots to compensate for the printer's non-printable left margin.
# Most Zebra printers clip ~28 dots on the left edge. Set to 0 to disable.
# ZLP_LABEL_LEFT_OFFSET=28

# Server bind address (rarely need to change these)
# ZLP_HOST=0.0.0.0
# ZLP_PORT=8099
